# ============================================================================
# Power BI Report Server to Power BI Online — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# Core assessment/export works with PBIRS credentials only.
# Import to PBI Online requires Azure AD credentials.
# ============================================================================

# ── PBIRS Connection ────────────────────────────────────────────────────────
PBIRS_SERVER_URL=https://pbirs.company.com/reports
PBIRS_USERNAME=
PBIRS_PASSWORD=
PBIRS_USE_WINDOWS_AUTH=true

# ── Azure AD / Power BI Online ──────────────────────────────────────────────
PBI_TENANT_ID=
PBI_CLIENT_ID=
PBI_CLIENT_SECRET=
PBI_WORKSPACE_ID=

# ── Fabric (optional) ──────────────────────────────────────────────────────
FABRIC_API_BASE_URL=https://api.powerbi.com/v1.0
USE_MANAGED_IDENTITY=false

# ── Optional Settings ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
DEPLOYMENT_TIMEOUT=300
RETRY_ATTEMPTS=3
RETRY_DELAY=5
PARALLEL_WORKERS=4
